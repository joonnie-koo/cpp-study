{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C Debug (WSL Native)",
            "type": "cppdbg",
            "request": "launch",
            // Path to the built C executable
            "program": "${workspaceFolder}/bin/${fileBasenameNoExtension}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            // This must match the 'label' in your tasks.json
            "preLaunchTask": "WSL: gcc build debug",
            "miDebuggerPath": "/usr/bin/gdb"
        },
        {
            "name": "C Release (WSL Native)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bin/${fileBasenameNoExtension}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "preLaunchTask": "WSL: gcc build release",
            "miDebuggerPath": "/usr/bin/gdb"
        }
    ]
}
